					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Tokens are in response\", function () {",
									"    const response = pm.response.json();",
									"    pm.environment.set(\"auth0-access-token\", response.accessToken);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
