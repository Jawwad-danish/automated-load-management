# API Configuration
PORT=4000
ORIGINS = 'http://localhost:8080' #CORS

# AWS Defaults
AWS_DEFAULT_REGION=us-east-1


# App Config related configurations
AWS_APPCONFIG_ENVIRONMENT=development
AWS_APPCONFIG_APPLICATION=Bobtail-lm
AWS_APPCONFIG_PROFILE=General
AWS_APPCONFIG_ENABLE_POOLING=true
AWS_APPCONFIG_POLL_INTERVAL=86400

# Database related configurations
DB_INITIAL_CONNECTION_TIMEOUT=30000

# CORS
ORIGINS = 'http://localhost:8080'

# Logging
NO_COLOR=true
LOG_LEVEL=debug